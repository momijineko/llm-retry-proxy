# 上游 LLM API 地址（不要带尾斜杠）
UPSTREAM_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2

# 监听地址与端口
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080
# 容器时区（影响日志时间）
TZ=Asia/Shanghai
# Docker 构建使用的 PyPI 镜像
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 重试间隔（秒），适用于 503/502/504/529 等
RETRY_INTERVAL=1.0
# 其它状态码（503/502/504/529）指数退避开关（true/false）。默认关闭，保持固定间隔。
# 开启后连续失败时等待时间按 1→2→4→8→16→32→60s 递增（含±20%抖动），缓解上游持续过载
RETRY_BACKOFF=false
# 其它状态码指数退避等待上限（秒）
RETRY_BACKOFF_MAX=60
# 429 专用重试间隔（秒），作为指数退避的基数。若上游 429 响应带 Retry-After 头则优先使用该头
RETRY_INTERVAL_429=5.0
# 429 指数退避开关（true/false）。开启后连续 429 时等待时间按 5→10→20→40→60s 递增（含±20%抖动），
# 避免多 Agent 同步重试触发 429 雪崩。关闭则回退到固定 RETRY_INTERVAL_429
RETRY_BACKOFF_429=true
# 429 指数退避等待上限（秒）
RETRY_BACKOFF_MAX_429=60
# 最大重试次数，0=无限重试直到成功
MAX_RETRIES=60
# 触发重试的上游状态码，逗号分隔（524=Cloudflare源站超时，常见于CF上游如aihub）
RETRY_STATUS_CODES=503,502,504,524,529,429
# 宽松重试/换key模式(on/off, 默认off)。开启后 5xx+429+401/403+网络异常 全部触发重试+换key，无需维护上面的状态码白名单
# 适合号池场景: 任何服务端/鉴权错误都自动降级到其它key。400/404/422等请求级错误仍直接透传(换key没用)
RETRY_BROAD=off

# ── 以下为并发竞速模式，会增加上游压力，非必要不建议开启 ──

# 竞速模式: off=串行重试(默认) / race=请求竞速(每轮N个齐发) / stagger=滚动竞速(交错补发)
HEDGE_MODE=off
# 竞速模式下同时在飞/每轮并发的最大请求数
MAX_CONCURRENT=10

# 读写超时（秒），流式下指两次数据间最大间隔
TIMEOUT=300
# 连接上游超时（秒）
CONNECT_TIMEOUT=10

# 供应商标签，写入每条重试记录，用于区分不同上游/账号
PROVIDER=xfyun
# 额外上游路由（按路径前缀），格式: prefix|url|provider，多组逗号分隔
# 匹配前缀的请求去掉前缀后转发到对应 url；未匹配的走默认 UPSTREAM_URL
# 示例: /anthropic 前缀的请求转发到 Anthropic 端点，provider 标签为 anthropic
# EXTRA_UPSTREAMS=/anthropic|https://api.anthropic.com|anthropic
# 多组示例: /anthropic|https://api.anthropic.com|anthropic,/gemini|https://generativelanguage.googleapis.com|gemini
EXTRA_UPSTREAMS=

# 号池配置（可选）。留空则保持原有透传客户端 key 行为。
# 方式一(推荐): CSV 文件批量配置，格式 key,url,provider（行序=优先级，上=便宜下=贵）
#   复制 key_pool.csv.example 为 key_pool.csv 编辑后取消下面注释
# KEY_POOL_FILE=key_pool.csv
# 方式二: 环境变量配置（KEY_POOL_FILE 未设置或文件不存在时生效）
# 格式: key1;key2;key3 （按倍率从低到高排列，用于默认上游 UPSTREAM_URL）
# 多上游: url|provider|key1;key2,url2|provider2|key3;key4
# 请求时优先低倍率(便宜)key，遇到429/5xx自动降级到高倍率(贵)key，该key冷却后恢复
# 示例: sk-cheap-group;sk-normal-group;sk-premium-group
KEY_POOLS=
# 单个 key 遇到 429/5xx 后冷却时间（秒），冷却期间优先跳过该 key
KEY_COOLDOWN=30
# key 粘性持续时间（秒）。选定一个 key 后保持使用直到该时间过期或被限流，避免频繁切换导致上游缓存失效
KEY_STICKY=60
# 注入鉴权头的 header 名（默认 authorization）
# KEY_AUTH_HEADER=authorization
# 鉴权 scheme 前缀（默认 Bearer，设为空则只放裸 key）
# KEY_AUTH_SCHEME=Bearer

# 日志目录，明细按天拆分为 retry_YYYY-MM-DD.jsonl，累计汇总存 _summary.json
LOG_DIR=logs
# 明细日志保留天数，超期自动删除（0=不清理），累计汇总不受影响
LOG_RETENTION_DAYS=30

# 日志级别
LOG_LEVEL=INFO

# 请求正文敏感信息防误传：off=关闭 / audit=仅告警 / redact=替换后继续 / block=拦截
DLP_MODE=off
# 启用的规则：credentials / private_key / id_card / bank_card
DLP_RULES=credentials,private_key,jwt,connection_string,id_card,bank_card,structured_secret
# 规则文件路径；默认使用带注释的 retry_proxy/dlp_rules.yaml，也兼容 JSON
# DLP_RULE_FILE=/app/retry_proxy/dlp_rules.yaml
# 包在这对标记内的内容跳过检测；标记默认在转发上游前移除
DLP_EXEMPT_START=[[ALLOW_SENSITIVE]]
DLP_EXEMPT_END=[[/ALLOW_SENSITIVE]]
DLP_STRIP_EXEMPT_MARKERS=true
# 最大扫描请求体字节数；block 模式下超限请求返回 413
DLP_MAX_BODY_BYTES=1048576

# 出站请求是否跟随系统代理环境变量(HTTP_PROXY/HTTPS_PROXY/ALL_PROXY)
# false=直连(默认,国内上游最稳,不受本地代理开关影响)
# true=跟随系统代理(代理软件通常会跳过国内域名;访问国外上游如anthropic/gemini时建议开启)
TRUST_ENV=false
