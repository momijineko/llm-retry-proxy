# =============================================================================
# Docker 与运行环境
# =============================================================================

# 容器时区（影响日志时间）。
TZ=Asia/Shanghai

# Docker 构建使用的 PyPI 镜像。
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple


# =============================================================================
# 服务与访问控制
# =============================================================================

LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# 管理页面密码；未配置时 /stats*、/logs* 和 /admin/key-pools 禁用。
ADMIN_PASSWORD=

# HTTPS 部署时设为 true，使登录 Cookie 仅通过 HTTPS 发送。
ADMIN_COOKIE_SECURE=false

# 兼容旧配置：ADMIN_PASSWORD 留空时回退读取 ADMIN_TOKEN。
# ADMIN_TOKEN=

# 下游使用号池的凭据；不匹配时仅作普通透传。
PROXY_API_KEY=


# =============================================================================
# 上游、路由与网络
# =============================================================================

# 默认上游地址，不要带尾斜杠。
UPSTREAM_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
PROVIDER=xfyun

# 格式：prefix|url|provider，多组用逗号分隔；转发时去掉匹配前缀。
# 示例：/anthropic|https://api.anthropic.com|anthropic
EXTRA_UPSTREAMS=

# 是否读取 HTTP_PROXY/HTTPS_PROXY/ALL_PROXY；国内上游通常建议直连。
TRUST_ENV=false


# =============================================================================
# 连接与响应超时（秒）
# =============================================================================

CONNECT_TIMEOUT=10

# 普通读写超时；流式响应中表示相邻两次数据之间的最大间隔。
TIMEOUT=300

# 整笔 Responses 请求从开始处理到收到响应头的硬上限；0=不限制。
RESPONSES_HEADER_TIMEOUT=120


# =============================================================================
# 重试与退避
# =============================================================================

# 最大重试次数；0=无限重试。
MAX_RETRIES=60
RETRY_STATUS_CODES=503,502,504,524,529,429

# 开启后，5xx、429、401/403 和网络异常均触发重试或换 key。
RETRY_BROAD=off

# 非 429 错误：默认固定间隔；开启指数退避后最高等待 60 秒。
RETRY_INTERVAL=1.0
RETRY_BACKOFF=false
RETRY_BACKOFF_MAX=60

# 429：优先尊重 Retry-After，默认启用指数退避。
RETRY_INTERVAL_429=5.0
RETRY_BACKOFF_429=true
RETRY_BACKOFF_MAX_429=60


# =============================================================================
# 竞速模式（会增加上游压力）
# =============================================================================

# off=串行重试，race=每轮并发竞速，stagger=交错补发。
HEDGE_MODE=off
MAX_CONCURRENT=10


# =============================================================================
# 号池来源与鉴权
# =============================================================================

# CSV 优先于 KEY_POOLS；复制 key_pool.csv.example 后取消下一行注释。
# KEY_POOL_FILE=key_pool.csv

# 分号分隔 key；多上游格式：url|provider|key1;key2。
KEY_POOLS=

# 自定义上游鉴权头；默认使用 Authorization: Bearer <key>。
# KEY_AUTH_HEADER=authorization
# KEY_AUTH_SCHEME=Bearer


# =============================================================================
# 号池熔断与选择
# =============================================================================

# 旧版兼容值；未配置 KEY_COOLDOWN_5XX 时作为默认冷却时间。
KEY_COOLDOWN=30

KEY_COOLDOWN_5XX=30
KEY_COOLDOWN_429=60
KEY_COOLDOWN_AUTH=1800
KEY_COOLDOWN_MAX=3600
KEY_COOLDOWN_BACKOFF=true

# key 粘性空闲超时；0=禁用。
KEY_STICKY=120

# 所有候选 key 均熔断时的最长等待时间；超时返回 503，0=不限制。
KEY_POOL_WAIT_TIMEOUT=120


# =============================================================================
# 在线同步
# =============================================================================

KEY_POOL_SYNC_DEFAULT_ADAPTER=sub2api

# 管理页新增连接时预填的上游地址；留空时使用 UPSTREAM_URL。
# KEY_POOL_SYNC_URL=https://aihub.top

# 自动同步周期；0=仅手动同步。
KEY_POOL_SYNC_INTERVAL=300
KEY_POOL_CREATE_DELAY=1.5

# 同步连接、刷新令牌与最近成功号池的持久化文件，权限自动设为 0600。
# KEY_POOL_SYNC_STATE_FILE=/app/logs/.key_pool_sync.json


# =============================================================================
# 上游兼容
# =============================================================================

# 图片请求覆盖客户端身份，兼容限制默认 Python User-Agent 的上游。
IMAGE_UPSTREAM_USER_AGENT=
IMAGE_UPSTREAM_ORIGINATOR=


# =============================================================================
# 日志
# =============================================================================

LOG_DIR=logs
LOG_RETENTION_DAYS=30
LOG_LEVEL=INFO

# 旧版单文件日志路径，仅用于自动迁移。
# LOG_FILE=retry_log.jsonl


# =============================================================================
# 请求正文敏感信息防护
# =============================================================================

# off=关闭，audit=仅告警，redact=脱敏后转发，block=拦截。
DLP_MODE=off
DLP_RULES=private_key,ai_tokens,code_tokens,cloud_tokens,saas_tokens,package_tokens,credentials,csv_credentials,jwt,connection_string,id_card,bank_card,structured_secret

# 默认读取 retry_proxy/dlp_rules.yaml；也支持自定义 JSON/YAML 文件。
# DLP_RULE_FILE=/app/retry_proxy/dlp_rules.yaml

# 标记区间内跳过检查；默认在转发前移除标记。
DLP_EXEMPT_START=[[ALLOW_SENSITIVE]]
DLP_EXEMPT_END=[[/ALLOW_SENSITIVE]]
DLP_STRIP_EXEMPT_MARKERS=true

# 最大扫描字节数；redact/block 模式下超限返回 413。
DLP_MAX_BODY_BYTES=16777216
