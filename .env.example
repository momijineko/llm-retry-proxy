# 上游 LLM API 地址（不要带尾斜杠）
UPSTREAM_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2

# 监听地址与端口
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# 重试间隔（秒），适用于 503/502/504/529 等
RETRY_INTERVAL=1.0
# 429 专用重试间隔（秒），若上游 429 响应带 Retry-After 头则优先使用该头
RETRY_INTERVAL_429=5.0
# 最大重试次数，0=无限重试直到成功
MAX_RETRIES=60
# 触发重试的上游状态码，逗号分隔
RETRY_STATUS_CODES=503,502,504,529,429

# 竞速模式: off=串行重试(默认) / race=请求竞速(每轮N个齐发) / stagger=滚动竞速(交错补发)
HEDGE_MODE=off
# 竞速模式下同时在飞/每轮并发的最大请求数
MAX_CONCURRENT=10

# 读写超时（秒），流式下指两次数据间最大间隔
TIMEOUT=300
# 连接上游超时（秒）
CONNECT_TIMEOUT=10

# 供应商标签，写入每条重试记录，用于区分不同上游/账号
PROVIDER=xfyun
# 额外上游路由（按路径前缀），格式: prefix|url|provider，多组逗号分隔
# 匹配前缀的请求去掉前缀后转发到对应 url；未匹配的走默认 UPSTREAM_URL
# 示例: /anthropic 前缀的请求转发到 Anthropic 端点，provider 标签为 anthropic
# EXTRA_UPSTREAMS=/anthropic|https://api.anthropic.com|anthropic
# 多组示例: /anthropic|https://api.anthropic.com|anthropic,/gemini|https://generativelanguage.googleapis.com|gemini
EXTRA_UPSTREAMS=
# 日志目录，明细按天拆分为 retry_YYYY-MM-DD.jsonl，累计汇总存 _summary.json
LOG_DIR=logs
# 明细日志保留天数，超期自动删除（0=不清理），累计汇总不受影响
LOG_RETENTION_DAYS=30

# 日志级别
LOG_LEVEL=INFO

# 出站请求是否跟随系统代理环境变量(HTTP_PROXY/HTTPS_PROXY/ALL_PROXY)
# false=直连(默认,国内上游最稳,不受本地代理开关影响)
# true=跟随系统代理(代理软件通常会跳过国内域名;访问国外上游如anthropic/gemini时建议开启)
TRUST_ENV=false
